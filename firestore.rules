rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidDate(date) {
      return date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    // Daily Training Configs
    match /dailyConfigs/{date} {
      // Anyone authenticated can read
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create/update (admin check done in app)
      // Allow both old format (target) and new format (targets array + confirmed)
      allow create, update: if isAuthenticated() && 
                                isValidDate(date) &&
                                request.resource.data.date == date &&
                                (
                                  // New format: targets array
                                  (request.resource.data.keys().hasAll(['targets', 'confirmed']) &&
                                   request.resource.data.targets is list &&
                                   request.resource.data.confirmed is bool) ||
                                  // Old format: single target
                                  (request.resource.data.target is int &&
                                   request.resource.data.target >= 1 &&
                                   request.resource.data.target <= 12)
                                );
      // Allow delete for development/testing
      allow delete: if isAuthenticated();
    }

    // User Daily Progress
    match /userDailyProgress/{docId} {
      // Document ID format: {userId}_{date}
      // Allow users to read their own progress or anyone authenticated to read
      allow read: if isAuthenticated();
      
      // Helper to validate roll value (1-12 or 0 for placeholder)
      function isValidRoll(roll) {
        return roll is int && ((roll >= 1 && roll <= 12) || roll == 0);
      }
      
      // Helper to validate verified status
      function isValidVerified(verified) {
        return verified is string && (verified == 'pending' || verified == 'approved' || verified == 'rejected');
      }

      // Helper to validate practice mode
      function isValidPracticeMode(mode) {
        return mode is string && (mode == 'admin' || mode == 'pvp');
      }

      // Helper to validate practice state
      function isValidPracticeState(state) {
        return state is string && (state == 'waiting' || state == 'live' || state == 'finished');
      }
      
      // Users can create their own progress (partial or complete)
      // The userId comes from Google Sheets characterId, not Firebase Auth UID
      // Supports both normal training and PvP practice with optional fields
      allow create: if isAuthenticated() &&
                       docId == request.resource.data.userId + '_' + request.resource.data.date &&
                       request.resource.data.rolls.size() == 5 &&
                       isValidRoll(request.resource.data.rolls[0]) &&
                       isValidRoll(request.resource.data.rolls[1]) &&
                       isValidRoll(request.resource.data.rolls[2]) &&
                       isValidRoll(request.resource.data.rolls[3]) &&
                       isValidRoll(request.resource.data.rolls[4]) &&
                       request.resource.data.target is int &&
                       request.resource.data.target >= 1 &&
                       request.resource.data.target <= 12 &&
                       request.resource.data.success is bool &&
                       request.resource.data.completed is bool &&
                       isValidVerified(request.resource.data.verified) &&
                       isValidDate(request.resource.data.date) &&
                       // Validate practice mode if present
                       (!request.resource.data.keys().hasAny(['practiceMode']) || isValidPracticeMode(request.resource.data.practiceMode)) &&
                       (!request.resource.data.keys().hasAny(['practiceState']) || isValidPracticeState(request.resource.data.practiceState));
      
      // Allow updates for partial progress or PvP practice updates
      // PvP can update even when completed (to change from 'live' to 'finished')
      allow update: if isAuthenticated() &&
                       docId == request.resource.data.userId + '_' + request.resource.data.date &&
                       request.resource.data.rolls.size() == 5 &&
                       isValidRoll(request.resource.data.rolls[0]) &&
                       isValidRoll(request.resource.data.rolls[1]) &&
                       isValidRoll(request.resource.data.rolls[2]) &&
                       isValidRoll(request.resource.data.rolls[3]) &&
                       isValidRoll(request.resource.data.rolls[4]) &&
                       request.resource.data.target is int &&
                       request.resource.data.target >= 1 &&
                       request.resource.data.target <= 12 &&
                       request.resource.data.success is bool &&
                       request.resource.data.completed is bool &&
                       isValidVerified(request.resource.data.verified) &&
                       isValidDate(request.resource.data.date) &&
                       // Validate practice mode if present
                       (!request.resource.data.keys().hasAny(['practiceMode']) || isValidPracticeMode(request.resource.data.practiceMode)) &&
                       (!request.resource.data.keys().hasAny(['practiceState']) || isValidPracticeState(request.resource.data.practiceState));
      
      // Allow deletes for development/testing (in production, you can restrict this to admins)
      allow delete: if isAuthenticated();
    }
  }
}
