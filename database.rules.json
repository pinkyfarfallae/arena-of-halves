{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "arena": {
      ".read": "auth != null",
      ".write": "auth != null",
      
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "trainingQuotas": {
      ".read": "auth != null",
      
      "$characterId": {
        ".write": "auth != null && auth.uid != null",
        
        "$date": {
          ".validate": "newData.hasChildren(['used', 'timestamp'])"
        }
      }
    }
  }
}
