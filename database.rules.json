{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    
    "arena": {
      ".read": "auth != null",
      ".write": "auth != null",
      
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    
    "trainingQuotas": {
      ".read": "auth != null",
      ".write": "auth != null",
      
      "$characterId": {
        "$date": {
          ".validate": "newData.hasChildren(['used', 'timestamp']) || newData.hasChildren(['used', 'timestamp', 'mode'])"
        }
      }
    }
  }
}
